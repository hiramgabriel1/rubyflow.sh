{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "sh",
          "cmd": "sh",
          "args": [
            {
              "validator": ".*"
            }
          ]
        },
        {
          "name": "bash",
          "cmd": "bash",
          "args": [
            {
              "validator": ".*"
            }
          ]
        },
        {
          "name": "zsh",
          "cmd": "zsh",
          "args": [
            {
              "validator": ".*"
            }
          ]
        }
      ]
    }
  ]
}
